---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Jonathan O'Driscoll"
  description="Practical advice for UK local businesses on social media, SEO, and getting found online."
>
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="max-w-2xl mb-14">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">Blog</h1>
      <p class="text-xl text-gray-600 leading-relaxed">
        Practical advice on social media, SEO, and getting your local business found online.
      </p>
    </div>

    {posts.length === 0 ? (
      <div class="text-center py-20 text-gray-500">
        <p class="text-lg">First articles coming soon.</p>
        <p class="text-sm mt-2">In the meantime, <a href="/audit" class="text-brand-blue hover:underline">download the free audit guide</a>.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {posts.map((post) => (
          <article class="border border-gray-200 rounded-xl p-6 hover:border-blue-200 transition-colors">
            <time class="text-xs text-gray-500 uppercase tracking-wide">
              {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            <h2 class="font-bold text-xl text-gray-900 mt-2 mb-3 leading-snug">
              <a href={`/blog/${post.slug}`} class="hover:text-brand-blue transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="text-gray-600 leading-relaxed mb-4">{post.data.description}</p>
            <a href={`/blog/${post.slug}`} class="text-brand-blue font-semibold text-sm hover:underline">
              Read article &rarr;
            </a>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
