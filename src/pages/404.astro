---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found — Jonathan O'Driscoll" description="This page doesn't exist.">
  <section class="max-w-xl mx-auto px-6 py-32 text-center">
    <p class="text-brand-blue font-bold text-sm uppercase tracking-wide mb-4">404</p>
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Page not found</h1>
    <p class="text-gray-600 mb-8">That page doesn't exist. Let's get you back on track.</p>
    <a href="/" class="inline-block bg-brand-blue text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors">
      Go to homepage
    </a>
  </section>
</BaseLayout>
