---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free Local Business Online Presence Audit — Jonathan O'Driscoll"
  description="Download the free Local Business Online Presence Audit guide. Find out exactly where your business is invisible online and what to fix first."
>
  <section class="max-w-3xl mx-auto px-6 py-16 lg:py-24">
    <div class="text-center mb-12">
      <p class="text-brand-blue font-semibold text-sm uppercase tracking-wide mb-4">Free download</p>
      <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-6 leading-tight">
        Find out exactly why your business is invisible online.
      </h1>
      <p class="text-xl text-gray-600 leading-relaxed">
        The Local Business Online Presence Audit is a free step-by-step guide. Work through it in an afternoon and you'll know exactly what to fix and in what order.
      </p>
    </div>

    <!-- What's inside -->
    <div class="bg-gray-50 rounded-2xl p-8 mb-12">
      <h2 class="font-bold text-lg text-gray-900 mb-6">What the audit covers</h2>
      <ul class="space-y-4">
        <li class="flex gap-3">
          <span class="text-brand-blue font-bold mt-0.5">01</span>
          <div>
            <p class="font-semibold text-gray-900">Google Business Profile</p>
            <p class="text-gray-600 text-sm">The most underused free tool for local businesses. Most profiles are incomplete or actively hurting search visibility.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-brand-blue font-bold mt-0.5">02</span>
          <div>
            <p class="font-semibold text-gray-900">Website basics</p>
            <p class="text-gray-600 text-sm">Page speed, mobile, titles, descriptions, and whether Google can read your site at all.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-brand-blue font-bold mt-0.5">03</span>
          <div>
            <p class="font-semibold text-gray-900">Social media profiles</p>
            <p class="text-gray-600 text-sm">Whether your profiles build trust or raise doubt. Consistency, completeness, and what to prioritise.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-brand-blue font-bold mt-0.5">04</span>
          <div>
            <p class="font-semibold text-gray-900">Competitor comparison</p>
            <p class="text-gray-600 text-sm">What your top 3 local competitors are doing that you aren't. Where the quick wins are.</p>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="text-brand-blue font-bold mt-0.5">05</span>
          <div>
            <p class="font-semibold text-gray-900">Ranked action plan</p>
            <p class="text-gray-600 text-sm">A prioritised list of what to fix first, second, and third. No fluff, no jargon.</p>
          </div>
        </li>
      </ul>
    </div>

    <!-- Kit email capture form -->
    <div class="bg-white border-2 border-gray-200 rounded-2xl p-8">
      <h2 class="font-bold text-xl text-gray-900 mb-2">Get the free audit guide</h2>
      <p class="text-gray-600 text-sm mb-6">Enter your email and I'll send it straight over. No spam. Unsubscribe any time.</p>
      <script src="https://f.convertkit.com/ckjs/ck.5.js"></script>
      <form action="https://app.kit.com/forms/9238344/subscriptions" class="seva-form formkit-form" method="post" data-sv-form="9238344" data-uid="724f4b0e75" data-format="inline" data-version="5" min-width="400 500 600 700 800"><div data-style="clean"><ul class="formkit-alert formkit-alert-error" data-element="errors" data-group="alert"></ul><div data-element="fields" data-stacked="false" class="seva-fields formkit-fields"><div class="formkit-field"><input class="formkit-input" name="email_address" style="color: rgb(0, 0, 0); border-color: rgb(227, 227, 227); border-radius: 4px; font-weight: 400;" aria-label="Email Address" placeholder="Email Address" required="" type="email"></div><button data-element="submit" class="formkit-submit formkit-submit" style="color: rgb(255, 255, 255); background-color: rgb(22, 119, 190); border-radius: 4px; font-weight: 400;"><div class="formkit-spinner"><div></div><div></div><div></div></div><span class="">Send me the guide</span></button></div><div class="formkit-powered-by-convertkit-container"><a href="https://kit.com/features/forms?utm_campaign=poweredby&amp;utm_content=form&amp;utm_medium=referral&amp;utm_source=dynamic" data-element="powered-by" class="formkit-powered-by-convertkit" data-variant="dark" target="_blank" rel="nofollow">Built with Kit</a></div></div></form>
    </div>
  </section>
</BaseLayout>
